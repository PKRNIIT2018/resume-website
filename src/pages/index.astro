---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resumeData } from "../data/resumeData";

// Helper to render markdown bolding in HTML
const formatBold = (text: string) =>
  text.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Prasanth Kunnumal Ramesh, PMP® - Product Owner | Senior Technical Business Analyst"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content animate-on-scroll">
          <h1 class="hero-title">
            Hi, I'm <span class="highlight">{resumeData.personalInfo.name}</span
            >
          </h1>
          <p class="hero-subtitle">
            {resumeData.personalInfo.title} @ IBM | Agile Leader | {
              resumeData.hero.highlightLine
            }
          </p>
          <p class="hero-tagline">
            Experience augmented by AI is a superpower.
          </p>
          <p class="hero-description">
            I bridge enterprise IT delivery with AI-augmented workflows — turning complex requirements into high-velocity, production-ready solutions.
          </p>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-number">20+</span>
              <span class="stat-label">Years Experience</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">5</span>
              <span class="stat-label">Countries</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">PMP®</span>
              <span class="stat-label">Certified</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">30+</span>
              <span class="stat-label">Team Size Led</span>
            </div>
          </div>

          <div class="hero-actions">
            <a href="/portfolio" class="btn btn-primary">View My Work</a>
            <a href="/contact" class="btn btn-secondary">Get In Touch</a>
          </div>
        </div>
      </div>
    </section>

    <!-- About Preview Section -->
    <section class="section about-preview">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2>About Me</h2>
          <p class="section-description">
            A brief introduction to who I am and what I do
          </p>
        </div>
        <div class="about-content animate-on-scroll">
          <div class="about-text">
            <p set:html={formatBold(resumeData.executiveSummary)} />
            <p>
              My "secret sauce" is the integration of a self-initiated AI
              productivity stack, including <strong
                >watsonx Code Assistant</strong
              >,
              <strong>IBM BOB</strong>, <strong>Perplexity</strong> and
              <strong>Gemini</strong>. I leverage these tools to analyze complex
              logic and accelerate requirement drafting while maintaining strict
              enterprise standards.
            </p>
            <a href="/about" class="link-with-arrow">
              Learn more about me
              <span class="arrow">→</span>
            </a>
          </div>
          <div class="skills-preview">
            <h3>Core Skills</h3>
            {resumeData.skills.map((category) => (
              <div class="skills-category animate-on-scroll">
                <span class="skills-category-label">{category.category}</span>
                <div class="skills-grid">
                  {category.items.slice(0, 4).map((skill) => (
                    <span class="badge">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
            <a href="/portfolio" class="link-with-arrow" style="margin-top: 1rem; display: inline-flex;">
              See all skills <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-content animate-on-scroll">
          <h2>Let's Work Together</h2>
          <p>
            I'm always interested in hearing about new projects and
            opportunities.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-outline-white">Get In Touch</a>
            <button id="downloadResumeBtn" class="btn btn-outline-white">
              Download Resume
            </button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    import { generateDynamicResumePDF } from "../utils/pdfGenerator";

    const downloadBtn = document.getElementById("downloadResumeBtn");
    if (downloadBtn) {
      downloadBtn.addEventListener("click", () => {
        generateDynamicResumePDF();
      });
    }
  </script>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    padding: var(--space-10) 0;
    background: linear-gradient(135deg, var(--surface) 0%, white 100%);
  }

  .hero-content {
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
  }

  .hero-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: var(--text-2xl);
    color: var(--text-light);
    margin-bottom: var(--space-3);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--primary);
    margin-bottom: var(--space-2);
    font-style: italic;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: var(--text-2xl);
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-light);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background-color: var(--border);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Section Styles */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .section-header h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }

  .section-description {
    font-size: var(--text-lg);
    color: var(--text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .section-footer {
    text-align: center;
    margin-top: var(--space-6);
  }

  /* About Preview */
  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    align-items: start;
  }

  .about-text p {
    margin-bottom: var(--space-3);
    line-height: var(--leading-relaxed);
  }

  .skills-preview h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .skills-category {
    margin-bottom: var(--space-3);
  }

  .skills-category-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-light);
    margin-bottom: var(--space-1);
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  /* Link with Arrow */
  .link-with-arrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .link-with-arrow:hover {
    gap: var(--space-2);
  }

  .arrow {
    transition: transform var(--transition-fast);
  }

  .link-with-arrow:hover .arrow {
    transform: translateX(4px);
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: white;
    font-size: var(--text-4xl);
    margin-bottom: var(--space-3);
  }

  .cta-content p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-5);
    opacity: 0.95;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-actions .btn-outline-white {
    background-color: transparent;
    color: white;
    border: 2px solid white;
  }

  .cta-actions .btn-outline-white:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  /* Responsive Design */

  @media (max-width: 768px) {
    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-subtitle {
      font-size: var(--text-xl);
    }

    .stat-divider {
      display: none;
    }

    .about-content {
      grid-template-columns: 1fr;
    }

    .hero-actions,
    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn,
    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
