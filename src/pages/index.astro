---
import BaseLayout from "../layouts/BaseLayout.astro";
import { resumeData } from "../data/resumeData";

// Helper to render markdown bolding in HTML - escapes HTML entities first to prevent XSS
const escapeHtml = (str: string) =>
  str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const formatBold = (text: string) =>
  escapeHtml(text).replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Prasanth Kunnumal Ramesh, PMP® - Product Owner | Senior Technical Business Analyst"
>
  <Header />

  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <div class="hero-content animate-on-scroll">
          <h1 class="hero-title">
            Hi, I'm <span class="highlight">{resumeData.personalInfo.name}</span
            >
          </h1>
          <p class="hero-subtitle">
            {resumeData.personalInfo.title} @ IBM
          </p>
          
          <!-- Quick Contact Bar -->
          <div class="hero-contact-bar animate-on-scroll">
            <a href="#" data-u="prasanth.k.ramesh" data-d="gmail.com" class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>Email</span>
            </a>
            <a href={`https://${resumeData.personalInfo.linkedin}`} target="_blank" rel="noopener noreferrer" class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              <span>LinkedIn</span>
            </a>
            <div class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{resumeData.personalInfo.location}</span>
            </div>
            <div class="contact-item work-permit-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>🇸🇰 No Work Permit Needed</span>
            </div>
          </div>

          <p class="hero-tagline">
            Experience augmented by AI is a superpower.
          </p>
          <p class="hero-description">
            I bridge enterprise IT delivery with AI-augmented workflows — turning complex requirements into high-velocity, production-ready solutions.
          </p>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-number">20+</span>
              <span class="stat-label">Years Experience</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">5</span>
              <span class="stat-label">Countries</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">PMP®</span>
              <span class="stat-label">Certified</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-number">30+</span>
              <span class="stat-label">Team Size Led</span>
            </div>
          </div>

          <div class="hero-actions">
            <a href="/portfolio" class="btn btn-primary">View My Work</a>
            <a href="/contact" class="btn btn-secondary">Get In Touch</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust-bar">
      <div class="container">
        <p class="trust-label">Trusted Experience At</p>
        <div class="trust-logos">
          <span class="trust-logo">IBM</span>
          <span class="trust-logo">NVSSoft</span>
          <span class="trust-logo">Aptech Europe</span>
          <span class="trust-logo">Aptech Qatar</span>
          <span class="trust-logo">Aptech India</span>
        </div>
      </div>
    </section>

    <!-- Core Focus Section -->
    <section class="section core-focus">
      <div class="container">
        <div class="focus-grid">
          <div class="focus-card animate-on-scroll">
            <div class="focus-icon">🎯</div>
            <h3>Strategic PO</h3>
            <p>Driving product vision through Agile/Scrum delivery and stakeholder alignment.</p>
          </div>
          <div class="focus-card animate-on-scroll">
            <div class="focus-icon">⚙️</div>
            <h3>Technical BA</h3>
            <p>Deep SDLC expertise in requirements engineering, data mapping, and API logic.</p>
          </div>
          <div class="focus-card animate-on-scroll highlight-card">
            <div class="focus-icon">🤖</div>
            <h3>AI-Augmented</h3>
            <p>Multi-model stack across IBM, Google & Anthropic — accelerating delivery by 40%.</p>
            <div class="ai-tool-chips">
              <span class="ai-chip">Watson Orchestrate</span>
              <span class="ai-chip">watsonx</span>
              <span class="ai-chip">Gemini</span>
              <span class="ai-chip">Claude</span>
              <span class="ai-chip">Copilot</span>
              <span class="ai-chip">Ollama</span>
            </div>
            <div class="pulse-badge">High Velocity</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Preview Section -->
    <section class="section about-preview">
      <div class="container">
        <div class="section-header animate-on-scroll">
          <h2>Professional Summary</h2>
          <p class="section-description">
            Bridging the gap between business needs and technical execution.
          </p>
        </div>
        <div class="about-content animate-on-scroll">
          <div class="about-text">
            <p set:html={formatBold(resumeData.executiveSummary)} />
            <p>
              My unique edge is the integration of a self-initiated AI
              productivity stack, including <strong
                >watsonx Code Assistant</strong
              >,
              <strong>IBM BOB</strong>, <strong>Perplexity</strong> and
              <strong>Gemini</strong>. I leverage these tools to analyze complex
              logic and accelerate requirement drafting while maintaining strict
              enterprise standards.
            </p>
            <a href="/about" class="link-with-arrow">
              Learn more about my journey
              <span class="arrow">→</span>
            </a>
          </div>
          <div class="skills-preview">
            <h3>Top Competencies</h3>
            {resumeData.skills.map((category) => (
              <div class="skills-category animate-on-scroll">
                <span class="skills-category-label">{category.category}</span>
                <div class="skills-grid">
                  {category.items.slice(0, 5).map((skill) => (
                    <span class="badge">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
            <a href="/portfolio" class="link-with-arrow" style="margin-top: 1rem; display: inline-flex;">
              View all technical skills <span class="arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-content animate-on-scroll">
          <h2>Let's Work Together</h2>
          <p>
            I'm always interested in hearing about new projects and
            opportunities.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-outline-white">Get In Touch</a>
            <a href="/contact" class="btn btn-outline-white">
              Request CV
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    padding: var(--space-10) 0 var(--space-6);
    background: linear-gradient(135deg, var(--surface) 0%, white 100%);
  }

  .hero-content {
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
  }

  .hero-title {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-3);
    line-height: 1.2;
  }

  .highlight {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: var(--text-2xl);
    color: var(--text-light);
    margin-bottom: var(--space-4);
    font-weight: 500;
  }

  .hero-contact-bar {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-light);
    text-decoration: none;
    font-weight: 500;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
    padding: 0.5rem 1rem;
    background: white;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border);
  }

  .contact-item:hover {
    color: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--primary);
  }

  .work-permit-badge {
    background: #f0fdf4;
    border-color: #bbf7d0;
    color: #15803d;
    font-weight: 600;
  }

  .work-permit-badge:hover {
    color: #15803d;
    border-color: #22c55e;
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--primary);
    margin-bottom: var(--space-2);
    font-style: italic;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--text-light);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
    max-width: 650px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .stat-number {
    font-size: var(--text-2xl);
    font-weight: 800;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }

  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-light);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background-color: var(--border);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Trust Bar */
  .trust-bar {
    padding: var(--space-4) 0;
    background-color: white;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .trust-label {
    text-align: center;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-3);
  }

  .trust-logos {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    opacity: 0.6;
    filter: grayscale(1);
    transition: opacity var(--transition-base);
  }

  .trust-logos:hover {
    opacity: 1;
    filter: grayscale(0.5);
  }

  .trust-logo {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--secondary);
    letter-spacing: -0.02em;
  }

  /* Core Focus */
  .focus-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .focus-card {
    background: white;
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    text-align: center;
    transition: all var(--transition-base);
  }

  .focus-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--primary);
  }

  .focus-icon {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .focus-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
    color: var(--secondary);
  }

  .focus-card p {
    font-size: var(--text-sm);
    color: var(--text-light);
    line-height: 1.5;
  }

  .highlight-card {
    background: linear-gradient(to bottom, white, #f0f7ff);
    border-color: var(--primary);
    position: relative;
    overflow: hidden;
  }

  .ai-tool-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    justify-content: center;
    margin-top: var(--space-2);
  }

  .ai-chip {
    background: rgba(37, 99, 235, 0.08);
    color: var(--primary);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(37, 99, 235, 0.2);
  }

  .highlight-card .ai-chip {
    background: rgba(37, 99, 235, 0.12);
    border-color: rgba(37, 99, 235, 0.3);
  }

  .pulse-badge {
    position: absolute;
    top: 10px;
    right: -25px;
    background: var(--primary);
    color: white;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 30px;
    transform: rotate(45deg);
    text-transform: uppercase;
  }

  /* Section Styles */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-6);
  }

  .section-header h2 {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }

  .section-description {
    font-size: var(--text-lg);
    color: var(--text-light);
    max-width: 600px;
    margin: 0 auto;
  }

  /* About Preview */
  .about-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .about-text p {
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .skills-preview h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }

  .skills-category {
    margin-bottom: var(--space-4);
  }

  .skills-category-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-light);
    margin-bottom: var(--space-2);
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .badge {
    background: #f1f5f9;
    color: #475569;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  /* Link with Arrow */
  .link-with-arrow {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--primary);
    font-weight: 600;
    text-decoration: none;
    transition: gap var(--transition-fast);
  }

  .link-with-arrow:hover {
    gap: var(--space-2);
  }

  .arrow {
    transition: transform var(--transition-fast);
  }

  .link-with-arrow:hover .arrow {
    transform: translateX(4px);
  }

  /* CTA Section */
  .cta-section {
    background: linear-gradient(135deg, var(--primary), var(--accent));
    color: white;
  }

  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    color: white;
    font-size: var(--text-4xl);
    margin-bottom: var(--space-3);
  }

  .cta-content p {
    font-size: var(--text-lg);
    margin-bottom: var(--space-5);
    opacity: 0.95;
  }

  .cta-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-actions .btn-outline-white {
    background-color: transparent;
    color: white;
    border: 2px solid white;
  }

  .cta-actions .btn-outline-white:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }
  /* Responsive Design */

  @media (max-width: 768px) {
    .hero {
      padding: var(--space-6) 0 var(--space-4); /* 48px top instead of 80px */
    }

    .hero-title {
      font-size: var(--text-4xl);
    }

    .hero-subtitle {
      font-size: var(--text-xl);
    }

    /* Compact contact bar chips */
    .contact-item {
      font-size: 0.75rem;
      padding: 0.35rem 0.65rem;
      gap: 0.35rem;
    }

    .hero-contact-bar {
      gap: var(--space-1);
    }

    .stat-divider {
      display: none;
    }

    .focus-grid {
      grid-template-columns: 1fr;
    }

    /* Tighter card padding on mobile */
    .focus-card {
      padding: var(--space-3);
    }

    /* Readable chip size on mobile */
    .ai-chip {
      font-size: 0.75rem;
      padding: 0.25rem 0.6rem;
    }

    /* Shrink the ribbon badge proportionally */
    .pulse-badge {
      font-size: 9px;
      padding: 2px 24px;
      right: -20px;
    }

    .about-content {
      grid-template-columns: 1fr;
    }

    /* Visual separator between text and skills on mobile */
    .skills-preview {
      border-top: 1px solid var(--border);
      padding-top: var(--space-4);
    }

    /* Bump skills label from 12px to 13px */
    .skills-category-label {
      font-size: 0.8rem;
    }

    .hero-actions,
    .cta-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn,
    .cta-actions .btn {
      width: 100%;
    }
  }
</style>
