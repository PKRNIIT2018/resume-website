---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import careerJourney from "../assets/career-journey.jpg";
import { resumeData } from "../data/resumeData";

// Helper to render markdown bolding in HTML - escapes HTML entities first to prevent XSS
const escapeHtml = (str: string) =>
  str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
const formatBold = (text: string) =>
  escapeHtml(text).replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
---

<BaseLayout
  title="About Me - Prasanth Kunnumal Ramesh, PMP® | Product Owner & Technical Business Analyst"
  description="Learn more about my 20+ years of IT expertise, certifications, and professional journey."
>
  <Header />

  <main id="main-content">
    <!-- Hero Section -->
    <section class="page-hero">
      <div class="container">
        <h1 class="animate-on-scroll">Professional Profile</h1>
        <p class="lead animate-on-scroll">
          20+ Years of Bridging Enterprise Vision with Technical Execution
        </p>
      </div>
    </section>

    <!-- Professional Summary -->
    <section class="section">
      <div class="container">
        <div class="content-grid">
          <div class="main-content animate-on-scroll">
            <h2>Executive Summary</h2>
            <div class="summary-card">
              <p set:html={formatBold(resumeData.executiveSummary)} />
            </div>
            
            <!-- AI Specialization Section -->
            <div class="ai-specialization-block animate-on-scroll">
              <div class="ai-header">
                <span class="ai-icon">🤖</span>
                <div>
                  <h3>The AI-Augmented Advantage</h3>
                  <p class="ai-subheading">A practitioner-built stack — not a buzzword list</p>
                </div>
              </div>
              <p class="ai-intro">
                In today's landscape, experience is the foundation, but AI is the accelerator. I've built and actively use a multi-model productivity stack that compresses weeks of analysis into days — while maintaining enterprise-grade accuracy and compliance.
              </p>

              <!-- Tool Grid -->
              <div class="ai-tools-grid">
                <div class="ai-tool-card ibm-card">
                  <div class="tool-logo">🔵</div>
                  <div class="tool-info">
                    <span class="tool-name">IBM Watson Orchestrate</span>
                    <span class="tool-use">Agentic workflow automation & task orchestration across enterprise systems</span>
                  </div>
                </div>
                <div class="ai-tool-card ibm-card">
                  <div class="tool-logo">💡</div>
                  <div class="tool-info">
                    <span class="tool-name">IBM watsonx</span>
                    <span class="tool-use">Code analysis, legacy system understanding & requirement acceleration</span>
                  </div>
                </div>
                <div class="ai-tool-card ibm-card">
                  <div class="tool-logo">🧠</div>
                  <div class="tool-info">
                    <span class="tool-name">IBM BOB</span>
                    <span class="tool-use">Internal AI assistant for enterprise knowledge retrieval & documentation</span>
                  </div>
                </div>
                <div class="ai-tool-card google-card">
                  <div class="tool-logo">✨</div>
                  <div class="tool-info">
                    <span class="tool-name">Google Gemini</span>
                    <span class="tool-use">Research synthesis, regulatory analysis & cross-domain requirement drafting</span>
                  </div>
                </div>
                <div class="ai-tool-card google-card">
                  <div class="tool-logo">📚</div>
                  <div class="tool-info">
                    <span class="tool-name">NotebookLM</span>
                    <span class="tool-use">Synthesizing large technical documents, RFPs & legacy specs at speed</span>
                  </div>
                </div>
                <div class="ai-tool-card anthropic-card">
                  <div class="tool-logo">🔶</div>
                  <div class="tool-info">
                    <span class="tool-name">Claude (Anthropic)</span>
                    <span class="tool-use">Deep reasoning, BRD/FRD drafting, acceptance criteria & gap analysis</span>
                  </div>
                </div>
                <div class="ai-tool-card ms-card">
                  <div class="tool-logo">🪟</div>
                  <div class="tool-info">
                    <span class="tool-name">Microsoft Copilot</span>
                    <span class="tool-use">Enterprise productivity — meeting summaries, Jira/Confluence drafting</span>
                  </div>
                </div>
                <div class="ai-tool-card local-card">
                  <div class="tool-logo">🔒</div>
                  <div class="tool-info">
                    <span class="tool-name">Ollama (Local LLMs)</span>
                    <span class="tool-use">Privacy-first analysis of sensitive data — runs fully offline, zero cloud exposure</span>
                  </div>
                </div>
              </div>

              <!-- Workflow Stages -->
              <div class="workflow-pipeline">
                <div class="pipeline-stage">
                  <span class="pipeline-label">Discovery</span>
                  <div class="pipeline-tools">
                    <span class="ptag">NotebookLM</span>
                    <span class="ptag">Gemini</span>
                    <span class="ptag">Perplexity</span>
                  </div>
                  <p>Synthesize legacy docs, RFPs & domain knowledge in minutes</p>
                </div>
                <div class="pipeline-arrow">→</div>
                <div class="pipeline-stage">
                  <span class="pipeline-label">Analysis</span>
                  <div class="pipeline-tools">
                    <span class="ptag">watsonx</span>
                    <span class="ptag">Claude</span>
                    <span class="ptag">IBM BOB</span>
                  </div>
                  <p>Understand legacy code & draft requirements without SME dependency</p>
                </div>
                <div class="pipeline-arrow">→</div>
                <div class="pipeline-stage">
                  <span class="pipeline-label">Orchestration</span>
                  <div class="pipeline-tools">
                    <span class="ptag">Watson Orchestrate</span>
                    <span class="ptag">AntiGravity</span>
                  </div>
                  <p>Automate multi-step workflows across enterprise tools end-to-end</p>
                </div>
                <div class="pipeline-arrow">→</div>
                <div class="pipeline-stage">
                  <span class="pipeline-label">Delivery</span>
                  <div class="pipeline-tools">
                    <span class="ptag">Copilot</span>
                    <span class="ptag">Ollama</span>
                  </div>
                  <p>Draft BRDs, FRDs & user stories at 40% higher throughput</p>
                </div>
              </div>

              <div class="ai-impact-note">
                <strong>Net result:</strong> Analysis throughput improved by an estimated 30–40% · Legacy system onboarding reduced from weeks to days · Zero SME bottlenecks on documented systems
              </div>
            </div>
          </div>
          
          <div class="sidebar animate-on-scroll">
            <div class="info-card glass-panel">
              <h3>Professional Snapshot</h3>
              <ul class="info-list">
                <li><strong>Current:</strong> PO / Senior BA @ IBM</li>
                <li><strong>Certified:</strong> PMP®, MCT, Scrum</li>
                <li><strong>Global Exp:</strong> 5 Countries</li>
                <li><strong>Impact:</strong> 30+ Member Teams</li>
                <li><strong>Notice Period:</strong> {resumeData.personalInfo.noticePeriod}</li>
                <li>
                  <span class="work-auth-badge">
                    🇸🇰 {resumeData.personalInfo.workAuthorization}
                  </span>
                </li>
                <li>
                  <span class="status-badge">{resumeData.personalInfo.availability}</span>
                </li>
              </ul>
              <div class="sidebar-actions">
                <a href="/contact" class="btn btn-primary full-width">Request CV</a>
                <a href="/contact" class="btn btn-outline full-width">Get In Touch</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Experience -->
    <section class="section bg-surface">
      <div class="container">
        <h2 class="section-title animate-on-scroll">Career Journey</h2>
        <div class="timeline-refined">
          {
            resumeData.experience.map((exp: any) => (
              <div class="timeline-block animate-on-scroll">
                <div class="timeline-info">
                  <span class="timeline-year">{exp.period}</span>
                  <span class="timeline-company">{exp.company}</span>
                  <span class="timeline-location">{exp.location}</span>
                </div>
                <div class="timeline-details">
                  <h3 class="timeline-role">{exp.role}</h3>
                  <ul class="achievement-list">
                    {exp.achievements.slice(0, 4).map((ach: any) =>
                      typeof ach === "string" ? (
                        <li set:html={formatBold(ach)} />
                      ) : (
                        <li class="special-highlight">
                          <strong>{ach.title}</strong> {ach.items[0]}
                        </li>
                      ),
                    )}
                  </ul>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Visual Career Journey -->
    <section class="section infographic-section">
      <div class="container text-center">
        <h2 class="section-title animate-on-scroll">Visual Impact Mapping</h2>
        <p class="section-subtitle">A strategy-to-execution overview of my professional footprint.</p>
        <div class="infographic-preview-container animate-on-scroll" id="openInfographic">
            <Image
              src={careerJourney}
              alt="Career Journey Infographic"
              width={900}
              quality={80}
              loading="lazy"
            />
            <div class="overlay-hint">Click to Enlarge Impact Map</div>
        </div>
      </div>
    </section>

    <!-- Certifications -->
    <section class="section">
      <div class="container">
        <h2 class="section-title animate-on-scroll">Expertise & Credentials</h2>
        <div class="credentials-grid">
          <div class="cred-category animate-on-scroll">
            <h3>Key Certifications</h3>
            <ul class="cred-list">
              {resumeData.certifications.slice(0, 4).map(cert => <li>{cert}</li>)}
            </ul>
          </div>
          <div class="cred-category animate-on-scroll">
            <h3>Top Skills</h3>
            <div class="skills-flex">
              {resumeData.skills[1].items.slice(0, 8).map(skill => <span class="skill-tag">{skill}</span>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projector Modal -->
    <div id="infographicModal" class="infographic-modal">
      <div class="modal-overlay" id="closeInfographicArea"></div>
      <div class="modal-content">
        <button class="close-btn" id="closeInfographicBtn">&times;</button>
        <Image
          src={careerJourney}
          alt="Career Journey Full View"
          class="modal-image"
          quality={90}
          loading="eager"
        />
      </div>
    </div>

    <!-- Professional Endorsements -->
    <section class="section bg-surface">
      <div class="container">
        <h2 class="section-title animate-on-scroll">
          Professional Endorsements
        </h2>
        <div class="endorsements-grid animate-on-scroll">
          <div class="endorsement-card card">
            <h4>"The Solution Finder"</h4>
            <p>
              Colleagues describe Prasanth as an "honest employee with boundless
              energy" who focuses on solutions instead of problems.
            </p>
          </div>
          <div class="endorsement-card card">
            <h4>"The Expert Mentor"</h4>
            <p>
              Former students highlight his ability to explain "difficult issues in a simple, understandable way."
            </p>
          </div>
          <div class="endorsement-card card">
            <h4>"The Disciplined Leader"</h4>
            <p>
              Managers recognize him as "highly talented, dynamic, and very accurate" in complex technical roles.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="section cta-section">
      <div class="container">
        <div class="cta-content animate-on-scroll">
          <h2>Let's Connect</h2>
          <p>
            I'm always interested in discussing new opportunities,
            collaborations, or just connecting with fellow professionals.
          </p>
          <div class="cta-actions">
            <a href="/contact" class="btn btn-primary">Get In Touch</a>
            <a
              href="https://linkedin.com/in/prasanthkr"
              target="_blank"
              class="btn btn-secondary">LinkedIn Profile</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    // Modal Logic
    const openBtn = document.getElementById("openInfographic");
    const modal = document.getElementById("infographicModal");
    const closeBtn = document.getElementById("closeInfographicBtn");
    const closeArea = document.getElementById("closeInfographicArea");

    if (openBtn && modal) {
      openBtn.addEventListener("click", () => {
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
      });
      const closeModal = () => {
        modal.classList.remove("active");
        document.body.style.overflow = "";
      };
      closeBtn?.addEventListener("click", closeModal);
      closeArea?.addEventListener("click", closeModal);
    }
  </script>
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    padding: var(--space-8) 0 var(--space-6);
    background: linear-gradient(135deg, var(--surface) 0%, white 100%);
    text-align: center;
  }

  .page-hero h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-2);
  }

  .lead {
    font-size: var(--text-xl);
    color: var(--text-light);
    max-width: 700px;
    margin: 0 auto;
  }

  /* Content Grid */
  .content-grid {
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: var(--space-8);
  }

  .summary-card {
    background: white;
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--primary);
    box-shadow: var(--shadow-sm);
    margin-bottom: var(--space-6);
  }

  /* AI Specialization */
  .ai-specialization-block {
    background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
    padding: var(--space-6);
    border-radius: var(--radius-xl);
    border: 1px solid #dbeafe;
    margin-top: var(--space-6);
  }

  .ai-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: var(--space-3);
  }

  .ai-icon {
    font-size: 2rem;
    line-height: 1;
    margin-top: 2px;
  }

  .ai-header h3 {
    margin: 0 0 0.25rem;
    font-size: var(--text-xl);
    color: var(--primary);
  }

  .ai-subheading {
    margin: 0;
    font-size: var(--text-xs);
    color: var(--text-light);
    font-style: italic;
  }

  .ai-intro {
    font-size: var(--text-sm);
    line-height: 1.7;
    color: var(--text);
    margin-bottom: var(--space-5);
  }

  /* Tool Grid */
  .ai-tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .ai-tool-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.875rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid transparent;
    background: white;
    transition: all var(--transition-fast);
  }

  .ai-tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .ibm-card     { border-color: #dbeafe; }
  .ibm-card:hover { border-color: #3b82f6; }
  .google-card  { border-color: #dcfce7; }
  .google-card:hover { border-color: #22c55e; }
  .anthropic-card { border-color: #fef3c7; }
  .anthropic-card:hover { border-color: #f59e0b; }
  .ms-card      { border-color: #ede9fe; }
  .ms-card:hover { border-color: #8b5cf6; }
  .local-card   { border-color: #f1f5f9; }
  .local-card:hover { border-color: #64748b; }

  .tool-logo {
    font-size: 1.25rem;
    line-height: 1;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .tool-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .tool-name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--secondary);
  }

  .tool-use {
    font-size: 0.7rem;
    color: var(--text-light);
    line-height: 1.4;
  }

  /* Workflow Pipeline */
  .workflow-pipeline {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: var(--space-5);
    overflow-x: auto;
    padding-bottom: var(--space-2);
  }

  .pipeline-stage {
    flex: 1;
    min-width: 140px;
    background: white;
    border-radius: var(--radius-md);
    padding: var(--space-3);
    border: 1px solid #e2e8f0;
  }

  .pipeline-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--primary);
    margin-bottom: var(--space-1);
  }

  .pipeline-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: var(--space-1);
  }

  .ptag {
    background: #eff6ff;
    color: #2563eb;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.15rem 0.45rem;
    border-radius: var(--radius-sm);
  }

  .pipeline-stage p {
    font-size: 0.7rem;
    color: var(--text-light);
    margin: 0;
    line-height: 1.4;
  }

  .pipeline-arrow {
    font-size: 1.25rem;
    color: var(--primary);
    margin-top: var(--space-4);
    flex-shrink: 0;
    opacity: 0.4;
  }

  .ai-impact-note {
    background: linear-gradient(135deg, #1e3a8a10, #0ea5e910);
    border: 1px solid #bfdbfe;
    border-radius: var(--radius-md);
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    color: var(--secondary);
    line-height: 1.6;
  }

  .ai-impact-note strong {
    color: var(--primary);
  }

  /* Timeline Refined */
  .timeline-refined {
    max-width: 900px;
    margin: 0 auto;
  }

  .timeline-block {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
    position: relative;
  }

  .timeline-info {
    text-align: right;
  }

  .timeline-year {
    display: block;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--primary);
  }

  .timeline-company {
    display: block;
    font-weight: 600;
    font-size: var(--text-sm);
  }

  .timeline-location {
    display: block;
    font-size: var(--text-xs);
    color: var(--text-light);
  }

  .timeline-details {
    padding-left: var(--space-6);
    border-left: 2px solid var(--border);
    position: relative;
  }

  .timeline-details::before {
    content: "";
    position: absolute;
    left: -7px;
    top: 0;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--primary);
  }

  .timeline-role {
    margin-top: -5px;
    margin-bottom: var(--space-3);
    font-size: var(--text-xl);
  }

  .achievement-list {
    list-style: none;
    padding: 0;
  }

  .achievement-list li {
    font-size: var(--text-sm);
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.25rem;
    line-height: 1.6;
    color: var(--text-light);
  }

  .achievement-list li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: 700;
  }

  .special-highlight {
    color: var(--secondary) !important;
    font-weight: 500;
  }

  /* Sidebar */
  .info-card {
    background: white;
    padding: var(--space-5);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0;
  }

  .info-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: var(--text-sm);
  }

  .work-auth-badge {
    display: inline-block;
    background: #f0fdf4;
    color: #15803d;
    border: 1px solid #bbf7d0;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .status-badge {
    background: #ecfdf5;
    color: #059669;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
    font-weight: 700;
  }

  .sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: var(--space-4);
  }

  .btn-outline {
    background: transparent;
    border: 1px solid var(--primary);
    color: var(--primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }

  /* Credentials */
  .credentials-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .cred-list {
    list-style: none;
    padding: 0;
  }

  .cred-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: var(--text-sm);
  }

  .skills-flex {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
  }

  /* Infographic */
  .infographic-preview-container {
    cursor: pointer;
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    max-width: 800px;
    margin: 0 auto;
  }

  .overlay-hint {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0,0,0,0.6);
    color: white;
    padding: 1rem;
    font-weight: 700;
    backdrop-filter: blur(4px);
  }

  /* Endorsements */
  .endorsements-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  /* Modal */
  .infographic-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(8px);
    padding: var(--space-4);
  }

  .infographic-modal.active {
    display: flex;
  }

  .modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.9);
  }

  .modal-content {
    position: relative;
    max-width: 100%;
    max-height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .modal-image {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .close-btn {
    position: absolute;
    top: -40px;
    right: 0;
    color: white;
    background: none;
