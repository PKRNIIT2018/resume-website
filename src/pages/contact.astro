---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Contact Me - Prasanth Kunnumal Ramesh, PMP®"
  description="Get in touch with me for project inquiries, collaborations, or professional opportunities."
>
  <Header />

  <main id="main-content">
    <section class="contact-section">
      <div class="container">
        <div class="contact-wrapper">
          <h1>Get In Touch</h1>
          <p class="lead">
            Fill in the form below and I'll get back to you within 24–48 hours.
          </p>

          <form class="contact-form" id="contactForm" novalidate>
            <!-- Honeypot -->
            <div class="hp-field" aria-hidden="true">
              <input type="text" name="_honey" id="hp" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-group">
              <label for="name">Name <span class="required">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Your full name"
                autocomplete="name"
              />
              <span class="field-error" id="nameError"></span>
            </div>

            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your.email@example.com"
                autocomplete="email"
              />
              <span class="field-error" id="emailError"></span>
            </div>

            <div class="form-group">
              <label for="message">Message <span class="required">*</span></label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="How can I help you?"
              ></textarea>
              <span class="field-error" id="messageError"></span>
            </div>

            <div class="form-group checkbox-group">
              <input type="checkbox" id="requestCV" name="requestCV" />
              <label for="requestCV">I am requesting a copy of your CV.</label>
            </div>

            <div class="form-group checkbox-group">
              <input type="checkbox" id="privacy" name="privacy" />
              <label for="privacy">
                I agree to the <a href="/privacy" target="_blank">Privacy Policy</a> and consent to the processing of my data. <span class="required">*</span>
              </label>
            </div>

            <button type="submit" class="btn btn-primary full-width" id="submitBtn" disabled>
              Send Message
            </button>

            <p class="form-status" id="formStatus" aria-live="polite"></p>
          </form>

          <div class="alt-contact">
            <p>Prefer to connect directly?</p>
            <a
              href="https://linkedin.com/in/prasanthkr"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline"
            >
              <span class="linkedin-icon">in</span> Message me on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement;
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
  const formStatus = document.getElementById("formStatus") as HTMLParagraphElement;

  const nameInput = document.getElementById("name") as HTMLInputElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const messageInput = document.getElementById("message") as HTMLTextAreaElement;
  const privacyInput = document.getElementById("privacy") as HTMLInputElement;

  const nameError = document.getElementById("nameError") as HTMLSpanElement;
  const emailError = document.getElementById("emailError") as HTMLSpanElement;
  const messageError = document.getElementById("messageError") as HTMLSpanElement;

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  const FREE_DOMAINS = new Set([
    "gmail.com","googlemail.com","yahoo.com","yahoo.co.uk","yahoo.co.in","yahoo.fr",
    "yahoo.de","yahoo.es","yahoo.it","yahoo.ca","yahoo.com.au","ymail.com","rocketmail.com",
    "hotmail.com","hotmail.co.uk","hotmail.fr","hotmail.de","hotmail.it","hotmail.es",
    "outlook.com","outlook.co.uk","outlook.fr","outlook.de","live.com","live.co.uk",
    "live.fr","live.de","msn.com","icloud.com","me.com","mac.com","aol.com","aim.com",
    "protonmail.com","proton.me","protonmail.ch","tutanota.com","tutanota.de","tuta.io",
    "mail.com","email.com","gmx.com","gmx.net","gmx.de","gmx.at","gmx.ch",
    "zohomail.com","zoho.com","yandex.com","yandex.ru","mail.ru","inbox.ru","bk.ru",
    "list.ru","rambler.ru","rediffmail.com","sify.com","indiatimes.com",
    "fastmail.com","fastmail.fm","hushmail.com","guerrillamail.com","temp-mail.org",
    "dispostable.com","mailinator.com","trashmail.com","sharklasers.com","guerrillamailblock.com",
  ]);

  const ALLOWED_EMAILS = new Set(["pkrniit@gmail.com"]);

  function isFreeDomain(email: string): boolean {
    if (ALLOWED_EMAILS.has(email.toLowerCase())) return false;
    const domain = email.split("@")[1]?.toLowerCase();
    return domain ? FREE_DOMAINS.has(domain) : false;
  }

  function validateName(): boolean {
    const v = nameInput.value.trim();
    if (!v) { nameError.textContent = "Name is required."; return false; }
    if (v.length < 2) { nameError.textContent = "Name must be at least 2 characters."; return false; }
    nameError.textContent = "";
    return true;
  }

  function validateEmail(): boolean {
    const v = emailInput.value.trim();
    if (!v) { emailError.textContent = "Email is required."; return false; }
    if (!EMAIL_RE.test(v)) { emailError.textContent = "Please enter a valid email address."; return false; }
    if (isFreeDomain(v)) { emailError.textContent = "Please use a work or business email address."; return false; }
    emailError.textContent = "";
    return true;
  }

  function validateMessage(): boolean {
    const v = messageInput.value.trim();
    if (!v) { messageError.textContent = "Message is required."; return false; }
    if (v.length < 10) { messageError.textContent = "Message must be at least 10 characters."; return false; }
    messageError.textContent = "";
    return true;
  }

  function isEmailValid(): boolean {
    const v = emailInput.value.trim();
    return EMAIL_RE.test(v) && !isFreeDomain(v);
  }

  function checkForm() {
    const nameOk = nameInput.value.trim().length >= 2;
    const emailOk = isEmailValid();
    const messageOk = messageInput.value.trim().length >= 10;
    const privacyOk = privacyInput.checked;
    submitBtn.disabled = !(nameOk && emailOk && messageOk && privacyOk);
  }

  nameInput.addEventListener("input", () => { validateName(); checkForm(); });
  emailInput.addEventListener("input", () => { validateEmail(); checkForm(); });
  messageInput.addEventListener("input", () => { validateMessage(); checkForm(); });
  privacyInput.addEventListener("change", checkForm);

  // Show errors on blur only (not while typing)
  nameInput.addEventListener("blur", validateName);
  emailInput.addEventListener("blur", validateEmail);
  messageInput.addEventListener("blur", validateMessage);

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const hp = (document.getElementById("hp") as HTMLInputElement)?.value;
    if (hp) return;

    const allValid = validateName() && validateEmail() && validateMessage() && privacyInput.checked;
    if (!allValid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";
    formStatus.textContent = "";
    formStatus.className = "form-status";

    const name = nameInput.value.trim();
    const email = emailInput.value.trim();
    const message = messageInput.value.trim();
    const requestCV = (document.getElementById("requestCV") as HTMLInputElement)?.checked;

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, message, requestCV }),
      });

      if (res.ok) {
        form.reset();
        submitBtn.textContent = "Message Sent";
        formStatus.textContent = "Thanks! I'll get back to you within 24–48 hours.";
        formStatus.classList.add("success");
      } else {
        throw new Error("API error");
      }
    } catch {
      formStatus.textContent = "Something went wrong. Please try again or reach out on LinkedIn.";
      formStatus.classList.add("error");
      submitBtn.disabled = false;
      submitBtn.textContent = "Send Message";
    }
  });
</script>

<style>
  .contact-section {
    padding: var(--space-12) 0 var(--space-10);
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: flex-start;
  }

  .contact-wrapper {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-wrapper h1 {
    font-size: var(--text-5xl);
    margin-bottom: var(--space-2);
  }

  .lead {
    font-size: var(--text-lg);
    color: var(--text-light);
    margin-bottom: var(--space-6);
  }

  /* Form */
  .contact-form {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-group label {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--secondary);
  }

  .required {
    color: var(--primary);
  }

  .form-group input,
  .form-group textarea {
    padding: var(--space-3);
    border: 2px solid var(--border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-base);
    background: white;
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 140px;
  }

  .field-error {
    font-size: var(--text-sm);
    color: #dc2626;
    min-height: 1.2em;
  }

  .checkbox-group {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .checkbox-group input[type="checkbox"] {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.2rem;
    cursor: pointer;
    flex-shrink: 0;
    padding: 0;
    border: 2px solid var(--border);
  }

  .checkbox-group label {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--text-light);
    line-height: 1.5;
    cursor: pointer;
  }

  .checkbox-group a {
    color: var(--primary);
    text-decoration: underline;
  }

  .full-width {
    width: 100%;
    justify-content: center;
    padding: var(--space-3);
    font-size: var(--text-base);
  }

  .btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .form-status {
    margin: 0;
    font-size: var(--text-sm);
    text-align: center;
    min-height: 1.4em;
  }

  .form-status.success {
    color: #16a34a;
  }

  .form-status.error {
    color: #dc2626;
  }

  /* Alt contact */
  .alt-contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }

  .alt-contact p {
    margin: 0;
    color: var(--text-light);
    font-size: var(--text-sm);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-5);
    border: 2px solid var(--primary);
    border-radius: var(--radius-md);
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
  }

  .btn-outline:hover {
    background: var(--primary);
    color: white;
  }

  .linkedin-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.4rem;
    height: 1.4rem;
    background: var(--primary);
    color: white;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 700;
    transition: background var(--transition-fast);
  }

  .btn-outline:hover .linkedin-icon {
    background: white;
    color: var(--primary);
  }

  .hp-field {
    display: none;
    visibility: hidden;
  }

  @media (max-width: 768px) {
    .contact-section {
      padding: var(--space-8) 0 var(--space-8);
    }

    .contact-wrapper h1 {
      font-size: var(--text-4xl);
    }
  }
</style>
